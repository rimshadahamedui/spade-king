NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/r-spade?appName=RimozoCluster

# Redis
REDIS_URL=redis://127.0.0.1:6379

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# OAuth (optional in MVP)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Game
HEARTBEAT_INTERVAL_MS=15000
PLAYER_TIMEOUT_MS=60000
COUNTDOWN_SECONDS=5
ROOM_IDLE_TTL_SECONDS=3600

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
