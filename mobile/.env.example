# Copy to .env and set your machine's LAN IP when testing on a real phone.
# Find it: ipconfig (Windows) or ifconfig (Mac/Linux)
#
# Production
#   EXPO_PUBLIC_API_URL=https://spade.rimozo.com
#   EXPO_PUBLIC_SOCKET_URL=https://spade.rimozo.com
#
# Physical phone + Expo Go (same Wi‑Fi, local backend):
#   EXPO_PUBLIC_API_URL=http://192.168.x.x:4000
#
# Android emulator:
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:4000
#
# iOS simulator:
#   EXPO_PUBLIC_API_URL=http://localhost:4000

EXPO_PUBLIC_API_URL=https://spade.rimozo.com
EXPO_PUBLIC_SOCKET_URL=https://spade.rimozo.com
