{
  "name": "R-SPADE",
  "slug": "spade-king",
  "version": "1.0.0",
  "orientation": "landscape",
  "icon": "./assets/spade-club-logo.png",
  "userInterfaceStyle": "dark",
  "backgroundColor": "#000000",
  "splash": {
    "image": "./assets/spade-club-logo.png",
    "resizeMode": "contain",
    "backgroundColor": "#000000"
  },
  "ios": {
    "supportsTablet": true,
    "bundleIdentifier": "com.rimozo.rspade",
    "requireFullScreen": true,
    "backgroundColor": "#000000",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/spade-club-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000",
      "dark": {
        "image": "./assets/spade-club-logo.png",
        "backgroundColor": "#000000"
      }
    },
    "infoPlist": {
      "UIStatusBarStyle": "UIStatusBarStyleLightContent",
      "UIViewControllerBasedStatusBarAppearance": false,
      "ITSAppUsesNonExemptEncryption": false,
      "UISupportedInterfaceOrientations": [
        "UIInterfaceOrientationLandscapeLeft",
        "UIInterfaceOrientationLandscapeRight",
        "UIInterfaceOrientationLandscapeLeft",
        "UIInterfaceOrientationLandscapeRight"
      ],
      "UISupportedInterfaceOrientations~ipad": [
        "UIInterfaceOrientationLandscapeLeft",
        "UIInterfaceOrientationLandscapeRight",
        "UIInterfaceOrientationLandscapeLeft",
        "UIInterfaceOrientationLandscapeRight"
      ]
    }
  },
  "android": {
    "adaptiveIcon": {
      "foregroundImage": "./assets/spade-club-logo.png",
      "backgroundColor": "#000000"
    },
    "package": "com.rimozo.rspade",
    "softwareKeyboardLayoutMode": "resize",
    "backgroundColor": "#000000",
    "userInterfaceStyle": "dark",
    "screenOrientation": "landscape",
    "splash": {
      "image": "./assets/spade-club-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000",
      "dark": {
        "image": "./assets/spade-club-logo.png",
        "backgroundColor": "#000000"
      }
    }
  },
  "web": {
    "backgroundColor": "#000000",
    "output": "single",
    "bundler": "metro"
  },
  "plugins": [
    "expo-font",
    "expo-asset",
    [
      "expo-splash-screen",
      {
        "image": "./assets/spade-club-logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000",
        "imageWidth": 160,
        "dark": {
          "image": "./assets/spade-club-logo.png",
          "backgroundColor": "#000000"
        }
      }
    ],
    [
      "expo-screen-orientation",
      {
        "initialOrientation": "LANDSCAPE"
      }
    ]
  ],
  "extra": {
    "eas": {
      "projectId": "86193910-7fe0-4c75-b67c-b17469d0a576"
    }
  },
  "owner": "spadekings-team",
  "runtimeVersion": {
    "policy": "appVersion"
  },
  "updates": {
    "url": "https://u.expo.dev/86193910-7fe0-4c75-b67c-b17469d0a576"
  }
}
